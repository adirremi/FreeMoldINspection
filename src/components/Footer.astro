---
/**
 * Site footer. Rich with internal links (services, navigation, service areas)
 * to strengthen crawlability and SEO.
 */
import { SITE, formattedAddress } from "@data/site";
import Icon from "@components/Icon.astro";
import { Image } from "astro:assets";
import { getCollection } from "astro:content";
import logoIcon from "@assets/images/logo-icon.png";

const services = (await getCollection("services")).sort(
  (a, b) => a.data.order - b.data.order
);
const year = new Date().getFullYear();
---

<footer class="bg-ink-900 text-ink-200">
  <div class="mx-auto grid max-w-6xl gap-10 px-4 py-14 sm:px-6 md:grid-cols-2 lg:grid-cols-4">
    <!-- Brand + contact -->
    <div>
      <div class="flex items-center gap-3">
        <span class="inline-flex h-12 w-12 items-center justify-center rounded-xl bg-white p-1.5">
          <Image
            src={logoIcon}
            alt={`${SITE.name} shield logo`}
            width={80}
            height={80}
            class="h-full w-full object-contain"
            loading="lazy"
          />
        </span>
        <p class="text-lg font-extrabold text-white">
          Free Mold<span class="text-brand-400"> Inspection</span>
        </p>
      </div>
      <p class="mt-3 text-sm leading-relaxed text-ink-300">
        {SITE.tagline}. Certified, honest, and thorough mold services across
        South Florida.
      </p>
      <ul class="mt-5 space-y-3 text-sm">
        <li>
          <a href={SITE.phoneHref} class="flex items-center gap-2 hover:text-brand-300">
            <Icon name="phone" class="h-4 w-4 shrink-0 text-brand-400" />
            {SITE.phone}
          </a>
        </li>
        <li>
          <a href={`mailto:${SITE.email}`} class="flex items-center gap-2 hover:text-brand-300">
            <Icon name="mail" class="h-4 w-4 shrink-0 text-brand-400" />
            {SITE.email}
          </a>
        </li>
        <li class="flex items-start gap-2">
          <Icon name="map-pin" class="mt-0.5 h-4 w-4 shrink-0 text-brand-400" />
          <span>{formattedAddress()}</span>
        </li>
      </ul>
    </div>

    <!-- Services -->
    <nav aria-label="Footer services">
      <h2 class="text-sm font-bold uppercase tracking-wide text-white">Services</h2>
      <ul class="mt-4 space-y-2 text-sm">
        {
          services.map((service) => (
            <li>
              <a
                href={`/services/${service.id}/`}
                class="text-ink-300 hover:text-brand-300"
              >
                {service.data.shortTitle}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <!-- Company -->
    <nav aria-label="Footer navigation">
      <h2 class="text-sm font-bold uppercase tracking-wide text-white">Company</h2>
      <ul class="mt-4 space-y-2 text-sm">
        {
          SITE.nav.map((item) => (
            <li>
              <a href={item.href} class="text-ink-300 hover:text-brand-300">
                {item.label}
              </a>
            </li>
          ))
        }
        <li>
          <a href="/services/" class="text-ink-300 hover:text-brand-300">All Services</a>
        </li>
      </ul>
    </nav>

    <!-- Areas + hours -->
    <div>
      <h2 class="text-sm font-bold uppercase tracking-wide text-white">Areas We Serve</h2>
      <ul class="mt-4 flex flex-wrap gap-x-3 gap-y-2 text-sm text-ink-300">
        {SITE.areasServed.map((area) => <li>{area}</li>)}
      </ul>
      <h2 class="mt-6 text-sm font-bold uppercase tracking-wide text-white">Hours</h2>
      <ul class="mt-3 space-y-1 text-sm text-ink-300">
        {SITE.hours.map((line) => <li>{line}</li>)}
      </ul>
    </div>
  </div>

  <div class="border-t border-ink-800">
    <div class="mx-auto flex max-w-6xl flex-col items-center justify-between gap-3 px-4 py-6 text-xs text-ink-400 sm:flex-row sm:px-6">
      <p>&copy; {year} {SITE.legalName}. All rights reserved.</p>
      <p>Pembroke Park, FL &middot; Serving all of Broward County</p>
    </div>
  </div>
</footer>
