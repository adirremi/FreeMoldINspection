---
/**
 * Displays a single service using the "stretched link" pattern:
 * the title is the only focusable link, but its ::before overlay makes the
 * entire card clickable — accessible and keyboard-friendly with no extra JS.
 */
import Icon from "@components/Icon.astro";
import { type IconName } from "@lib/icons";

interface Props {
  title: string;
  summary: string;
  icon: IconName;
  href: string;
}

const { title, summary, icon, href } = Astro.props;
---

<article
  class="group relative flex flex-col rounded-2xl border border-ink-200 bg-white p-6 shadow-sm transition duration-200 hover:-translate-y-1 hover:border-brand-300 hover:shadow-lg"
>
  <span
    class="mb-4 inline-flex h-12 w-12 items-center justify-center rounded-xl bg-brand-50 text-brand-600 ring-1 ring-brand-100"
  >
    <Icon name={icon} class="h-6 w-6" />
  </span>

  <h3 class="text-lg font-bold text-ink-900">
    <a
      href={href}
      class="before:absolute before:inset-0 before:rounded-2xl before:content-[''] group-hover:text-brand-700"
    >
      {title}
    </a>
  </h3>

  <p class="mt-2 grow text-ink-700">{summary}</p>

  <span
    class="mt-4 inline-flex items-center gap-1 text-sm font-semibold text-brand-600"
  >
    Learn more
    <svg
      class="h-4 w-4 transition-transform group-hover:translate-x-1"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
    >
      <path d="M5 12h14M13 6l6 6-6 6" />
    </svg>
  </span>
</article>
