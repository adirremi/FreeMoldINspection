---
/**
 * Circular credentials cluster for the homepage hero.
 * Outer ring sized to fit inner badges snugly with balanced padding.
 */
import { Image } from "astro:assets";
import iicrcLogo from "@assets/images/iicrc-logo.png";

const licenses = [
  { code: "MRSA3365", title: "Mold Assessor" },
  { code: "MRSR3576", title: "Mold Remediator" },
] as const;
---

<div
  class="relative mx-auto shrink-0"
  aria-label="Licensed and certified credentials"
>
  <!-- Soft outer glow -->
  <div
    class="absolute -inset-5 rounded-full bg-gradient-to-br from-brand-400/40 via-accent-400/25 to-brand-600/40 blur-xl"
    aria-hidden="true"
  ></div>

  <!-- Outer ring — snug fit around inner content (+25% scale) -->
  <div
    class="relative aspect-square w-[21.875rem] overflow-hidden rounded-full border-2 border-white/35 bg-white/10 shadow-2xl ring-1 ring-white/20 backdrop-blur-md sm:w-[24.375rem] lg:w-[27.5rem]"
  >
    <div class="flex h-full w-full flex-col items-center justify-center px-5 py-5 text-center sm:px-6 sm:py-6">
      <p class="max-w-full text-[0.875rem] font-bold uppercase leading-tight tracking-wide text-brand-100 sm:text-[0.9375rem]">
        Licensed &amp; Certified
      </p>

      <!-- License badges -->
      <div class="mt-3 flex w-full items-start justify-center gap-2.5 sm:mt-4 sm:gap-4">
        {
          licenses.map((license) => (
            <div class="flex min-w-0 flex-col items-center">
              <span class="flex h-[5.9375rem] w-[5.9375rem] shrink-0 flex-col items-center justify-center rounded-full bg-gradient-to-br from-brand-500 to-brand-800 text-white shadow-lg ring-2 ring-white/40 sm:h-[6.5625rem] sm:w-[6.5625rem]">
                <span class="text-[0.6875rem] font-semibold uppercase tracking-wide text-brand-100 sm:text-[0.75rem]">
                  License
                </span>
                <span class="text-[0.9375rem] font-extrabold leading-tight sm:text-base">
                  {license.code}
                </span>
              </span>
              <span class="mt-2 max-w-[6.875rem] text-[0.75rem] font-semibold leading-tight text-white sm:max-w-[7.5rem] sm:text-[0.8125rem]">
                {license.title}
              </span>
            </div>
          ))
        }
      </div>

      <!-- IICRC -->
      <div class="mt-3 flex flex-col items-center sm:mt-4">
        <span class="flex h-[4.6875rem] w-[4.6875rem] shrink-0 items-center justify-center rounded-full bg-white p-2 shadow-lg ring-2 ring-accent-200/60 sm:h-[5.3125rem] sm:w-[5.3125rem] sm:p-2.5">
          <Image
            src={iicrcLogo}
            alt="IICRC Certified"
            width={120}
            height={120}
            class="h-full w-full object-contain"
            loading="eager"
          />
        </span>
        <span class="mt-2 text-[0.75rem] font-semibold text-white sm:text-[0.8125rem]">
          IICRC Certified
        </span>
      </div>
    </div>
  </div>
</div>
