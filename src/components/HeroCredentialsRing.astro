---
/**
 * Large circular credentials cluster for the homepage hero.
 * Groups Florida license badges and IICRC certification in one trust ring.
 */
import { Image } from "astro:assets";
import iicrcLogo from "@assets/images/iicrc-logo.png";

const licenses = [
  { code: "MRSA3365", title: "Mold Assessor" },
  { code: "MRSR3576", title: "Mold Remediator" },
] as const;
---

<div
  class="relative mx-auto w-full max-w-[17rem] sm:max-w-[19rem] lg:max-w-[21rem]"
  aria-label="Licensed and certified credentials"
>
  <!-- Soft outer glow -->
  <div
    class="absolute -inset-3 rounded-full bg-gradient-to-br from-brand-400/40 via-accent-400/25 to-brand-600/40 blur-2xl"
    aria-hidden="true"
  ></div>

  <!-- Main ring -->
  <div
    class="relative aspect-square rounded-full border-2 border-white/30 bg-white/10 p-5 shadow-2xl backdrop-blur-md ring-1 ring-white/20 sm:p-6"
  >
    <div class="flex h-full flex-col items-center justify-center text-center">
      <p class="text-[0.65rem] font-bold uppercase tracking-[0.2em] text-brand-100 sm:text-xs">
        Licensed &amp; Certified
      </p>

      <!-- License badges -->
      <div class="mt-3 flex w-full items-start justify-center gap-2 sm:mt-4 sm:gap-3">
        {
          licenses.map((license) => (
            <div class="flex flex-col items-center">
              <span class="flex h-[4.25rem] w-[4.25rem] flex-col items-center justify-center rounded-full bg-gradient-to-br from-brand-500 to-brand-800 text-white shadow-lg ring-2 ring-white/40 sm:h-[4.75rem] sm:w-[4.75rem]">
                <span class="text-[0.5rem] font-semibold uppercase tracking-wide text-brand-100">
                  License
                </span>
                <span class="text-[0.7rem] font-extrabold leading-tight sm:text-xs">
                  {license.code}
                </span>
              </span>
              <span class="mt-1.5 max-w-[5.5rem] text-[0.6rem] font-semibold leading-tight text-white sm:text-[0.65rem]">
                {license.title}
              </span>
            </div>
          ))
        }
      </div>

      <!-- IICRC -->
      <div class="mt-3 flex flex-col items-center sm:mt-4">
        <span class="flex h-14 w-14 items-center justify-center rounded-full bg-white p-2 shadow-lg ring-2 ring-accent-200/60 sm:h-[3.75rem] sm:w-[3.75rem]">
          <Image
            src={iicrcLogo}
            alt="IICRC Certified"
            width={80}
            height={80}
            class="h-full w-full object-contain"
            loading="eager"
          />
        </span>
        <span class="mt-1.5 text-[0.65rem] font-semibold text-white sm:text-xs">
          IICRC Certified
        </span>
      </div>
    </div>
  </div>
</div>
