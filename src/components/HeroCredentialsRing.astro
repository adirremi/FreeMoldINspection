---
/**
 * Circular credentials cluster for the homepage hero.
 * Outer ring sized to fit inner badges snugly with balanced padding.
 */
import { Image } from "astro:assets";
import iicrcLogo from "@assets/images/iicrc-logo.png";

const licenses = [
  { code: "MRSA3365", title: "Mold Assessor" },
  { code: "MRSR3576", title: "Mold Remediator" },
] as const;
---

<div
  class="relative mx-auto shrink-0"
  aria-label="Licensed and certified credentials"
>
  <!-- Soft outer glow -->
  <div
    class="absolute -inset-4 rounded-full bg-gradient-to-br from-brand-400/40 via-accent-400/25 to-brand-600/40 blur-xl"
    aria-hidden="true"
  ></div>

  <!-- Outer ring — snug fit around inner content -->
  <div
    class="relative aspect-square w-[17.5rem] overflow-hidden rounded-full border-2 border-white/35 bg-white/10 shadow-2xl ring-1 ring-white/20 backdrop-blur-md sm:w-[19.5rem] lg:w-[22rem]"
  >
    <div class="flex h-full w-full flex-col items-center justify-center px-4 py-4 text-center sm:px-5 sm:py-5">
      <p class="max-w-full text-[0.7rem] font-bold uppercase leading-tight tracking-wide text-brand-100 sm:text-xs">
        Licensed &amp; Certified
      </p>

      <!-- License badges -->
      <div class="mt-2.5 flex w-full items-start justify-center gap-2 sm:mt-3 sm:gap-3">
        {
          licenses.map((license) => (
            <div class="flex min-w-0 flex-col items-center">
              <span class="flex h-[4.75rem] w-[4.75rem] shrink-0 flex-col items-center justify-center rounded-full bg-gradient-to-br from-brand-500 to-brand-800 text-white shadow-lg ring-2 ring-white/40 sm:h-[5.25rem] sm:w-[5.25rem]">
                <span class="text-[0.55rem] font-semibold uppercase tracking-wide text-brand-100 sm:text-[0.6rem]">
                  License
                </span>
                <span class="text-xs font-extrabold leading-tight sm:text-sm">
                  {license.code}
                </span>
              </span>
              <span class="mt-1.5 max-w-[5.5rem] text-[0.6rem] font-semibold leading-tight text-white sm:max-w-[6rem] sm:text-[0.65rem]">
                {license.title}
              </span>
            </div>
          ))
        }
      </div>

      <!-- IICRC -->
      <div class="mt-2.5 flex flex-col items-center sm:mt-3">
        <span class="flex h-[3.75rem] w-[3.75rem] shrink-0 items-center justify-center rounded-full bg-white p-1.5 shadow-lg ring-2 ring-accent-200/60 sm:h-[4.25rem] sm:w-[4.25rem] sm:p-2">
          <Image
            src={iicrcLogo}
            alt="IICRC Certified"
            width={96}
            height={96}
            class="h-full w-full object-contain"
            loading="eager"
          />
        </span>
        <span class="mt-1.5 text-[0.6rem] font-semibold text-white sm:text-[0.65rem]">
          IICRC Certified
        </span>
      </div>
    </div>
  </div>
</div>
