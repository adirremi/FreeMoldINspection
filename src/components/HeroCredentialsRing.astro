---
/**
 * Large circular credentials cluster for the homepage hero.
 * Groups Florida license badges and IICRC certification in one trust ring.
 * All labels stay inside the outer circle via overflow clipping and inset padding.
 */
import { Image } from "astro:assets";
import iicrcLogo from "@assets/images/iicrc-logo.png";

const licenses = [
  { code: "MRSA3365", title: "Mold Assessor" },
  { code: "MRSR3576", title: "Mold Remediator" },
] as const;
---

<div
  class="relative mx-auto w-full max-w-[30.6rem] sm:max-w-[34.2rem] lg:max-w-[37.8rem]"
  aria-label="Licensed and certified credentials"
>
  <!-- Soft outer glow -->
  <div
    class="absolute -inset-6 rounded-full bg-gradient-to-br from-brand-400/40 via-accent-400/25 to-brand-600/40 blur-2xl"
    aria-hidden="true"
  ></div>

  <!-- Main ring — overflow hidden keeps every label inside the circle -->
  <div
    class="relative aspect-square overflow-hidden rounded-full border-2 border-white/30 bg-white/10 shadow-2xl ring-1 ring-white/20 backdrop-blur-md"
  >
    <div class="flex h-full w-full flex-col items-center justify-center px-[11%] py-[10%] text-center">
      <p class="max-w-full text-[1.17rem] font-bold uppercase leading-tight tracking-wide text-brand-100 sm:text-[1.2rem]">
        Licensed &amp; Certified
      </p>

      <!-- License badges -->
      <div class="mt-4 flex w-full max-w-full items-start justify-center gap-3 sm:mt-5 sm:gap-6">
        {
          licenses.map((license) => (
            <div class="flex min-w-0 flex-col items-center">
              <span class="flex h-[7.65rem] w-[7.65rem] shrink-0 flex-col items-center justify-center rounded-full bg-gradient-to-br from-brand-500 to-brand-800 text-white shadow-lg ring-2 ring-white/40 sm:h-[8.55rem] sm:w-[8.55rem]">
                <span class="text-[0.9rem] font-semibold uppercase tracking-wide text-brand-100">
                  License
                </span>
                <span class="text-[1.26rem] font-extrabold leading-tight sm:text-xl">
                  {license.code}
                </span>
              </span>
              <span class="mt-2 max-w-[9.9rem] text-[1.08rem] font-semibold leading-tight text-white sm:text-[1.17rem]">
                {license.title}
              </span>
            </div>
          ))
        }
      </div>

      <!-- IICRC -->
      <div class="mt-4 flex flex-col items-center sm:mt-5">
        <span class="flex h-[6.3rem] w-[6.3rem] shrink-0 items-center justify-center rounded-full bg-white p-3 shadow-lg ring-2 ring-accent-200/60 sm:h-[6.75rem] sm:w-[6.75rem]">
          <Image
            src={iicrcLogo}
            alt="IICRC Certified"
            width={144}
            height={144}
            class="h-full w-full object-contain"
            loading="eager"
          />
        </span>
        <span class="mt-2 text-[1.17rem] font-semibold text-white sm:text-[1.2rem]">
          IICRC Certified
        </span>
      </div>
    </div>
  </div>
</div>
