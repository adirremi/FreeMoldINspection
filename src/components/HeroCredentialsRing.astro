---
/**
 * Large circular credentials cluster for the homepage hero.
 * The outer ring uses explicit dimensions so it visibly wraps all inner badges.
 */
import { Image } from "astro:assets";
import iicrcLogo from "@assets/images/iicrc-logo.png";

const licenses = [
  { code: "MRSA3365", title: "Mold Assessor" },
  { code: "MRSR3576", title: "Mold Remediator" },
] as const;
---

<div
  class="relative mx-auto shrink-0"
  aria-label="Licensed and certified credentials"
>
  <!-- Soft outer glow -->
  <div
    class="absolute -inset-8 rounded-full bg-gradient-to-br from-brand-400/40 via-accent-400/25 to-brand-600/40 blur-2xl"
    aria-hidden="true"
  ></div>

  <!-- Outer ring — fixed size so the circle itself grows, not just the inner badges -->
  <div
    class="relative aspect-square w-[22rem] overflow-hidden rounded-full border-[3px] border-white/35 bg-white/10 shadow-2xl ring-2 ring-white/15 backdrop-blur-md sm:w-[28rem] lg:w-[34rem] xl:w-[38rem]"
  >
    <div class="flex h-full w-full flex-col items-center justify-center px-[12%] py-[11%] text-center">
      <p class="max-w-full text-sm font-bold uppercase leading-tight tracking-wide text-brand-100 sm:text-base lg:text-lg">
        Licensed &amp; Certified
      </p>

      <!-- License badges -->
      <div class="mt-3 flex w-full max-w-full items-start justify-center gap-2 sm:mt-4 sm:gap-5 lg:mt-5 lg:gap-6">
        {
          licenses.map((license) => (
            <div class="flex min-w-0 flex-col items-center">
              <span class="flex h-[5.5rem] w-[5.5rem] shrink-0 flex-col items-center justify-center rounded-full bg-gradient-to-br from-brand-500 to-brand-800 text-white shadow-lg ring-2 ring-white/40 sm:h-[6.75rem] sm:w-[6.75rem] lg:h-[7.65rem] lg:w-[7.65rem]">
                <span class="text-[0.65rem] font-semibold uppercase tracking-wide text-brand-100 sm:text-xs lg:text-sm">
                  License
                </span>
                <span class="text-sm font-extrabold leading-tight sm:text-base lg:text-lg">
                  {license.code}
                </span>
              </span>
              <span class="mt-1.5 max-w-[7rem] text-[0.7rem] font-semibold leading-tight text-white sm:mt-2 sm:max-w-[8.5rem] sm:text-xs lg:text-sm">
                {license.title}
              </span>
            </div>
          ))
        }
      </div>

      <!-- IICRC -->
      <div class="mt-3 flex flex-col items-center sm:mt-4 lg:mt-5">
        <span class="flex h-[4.5rem] w-[4.5rem] shrink-0 items-center justify-center rounded-full bg-white p-2 shadow-lg ring-2 ring-accent-200/60 sm:h-[5.5rem] sm:w-[5.5rem] sm:p-2.5 lg:h-[6.3rem] lg:w-[6.3rem] lg:p-3">
          <Image
            src={iicrcLogo}
            alt="IICRC Certified"
            width={144}
            height={144}
            class="h-full w-full object-contain"
            loading="eager"
          />
        </span>
        <span class="mt-1.5 text-[0.7rem] font-semibold text-white sm:mt-2 sm:text-xs lg:text-sm">
          IICRC Certified
        </span>
      </div>
    </div>
  </div>
</div>
