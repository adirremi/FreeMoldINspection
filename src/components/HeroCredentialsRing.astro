---
/**
 * Large circular credentials cluster for the homepage hero.
 * Groups Florida license badges and IICRC certification in one trust ring.
 */
import { Image } from "astro:assets";
import iicrcLogo from "@assets/images/iicrc-logo.png";

const licenses = [
  { code: "MRSA3365", title: "Mold Assessor" },
  { code: "MRSR3576", title: "Mold Remediator" },
] as const;
---

<div
  class="relative mx-auto w-full max-w-[25.5rem] sm:max-w-[28.5rem] lg:max-w-[31.5rem]"
  aria-label="Licensed and certified credentials"
>
  <!-- Soft outer glow -->
  <div
    class="absolute -inset-5 rounded-full bg-gradient-to-br from-brand-400/40 via-accent-400/25 to-brand-600/40 blur-2xl"
    aria-hidden="true"
  ></div>

  <!-- Main ring -->
  <div
    class="relative aspect-square rounded-full border-2 border-white/30 bg-white/10 p-8 shadow-2xl backdrop-blur-md ring-1 ring-white/20 sm:p-9"
  >
    <div class="flex h-full flex-col items-center justify-center text-center">
      <p class="text-[0.975rem] font-bold uppercase tracking-[0.2em] text-brand-100 sm:text-base">
        Licensed &amp; Certified
      </p>

      <!-- License badges -->
      <div class="mt-5 flex w-full items-start justify-center gap-3 sm:mt-6 sm:gap-5">
        {
          licenses.map((license) => (
            <div class="flex flex-col items-center">
              <span class="flex h-[6.375rem] w-[6.375rem] flex-col items-center justify-center rounded-full bg-gradient-to-br from-brand-500 to-brand-800 text-white shadow-lg ring-2 ring-white/40 sm:h-[7.125rem] sm:w-[7.125rem]">
                <span class="text-[0.75rem] font-semibold uppercase tracking-wide text-brand-100">
                  License
                </span>
                <span class="text-[1.05rem] font-extrabold leading-tight sm:text-lg">
                  {license.code}
                </span>
              </span>
              <span class="mt-2 max-w-[8.25rem] text-[0.9rem] font-semibold leading-tight text-white sm:text-[0.975rem]">
                {license.title}
              </span>
            </div>
          ))
        }
      </div>

      <!-- IICRC -->
      <div class="mt-5 flex flex-col items-center sm:mt-6">
        <span class="flex h-[5.25rem] w-[5.25rem] items-center justify-center rounded-full bg-white p-3 shadow-lg ring-2 ring-accent-200/60 sm:h-[5.625rem] sm:w-[5.625rem]">
          <Image
            src={iicrcLogo}
            alt="IICRC Certified"
            width={120}
            height={120}
            class="h-full w-full object-contain"
            loading="eager"
          />
        </span>
        <span class="mt-2 text-[0.975rem] font-semibold text-white sm:text-base">
          IICRC Certified
        </span>
      </div>
    </div>
  </div>
</div>
