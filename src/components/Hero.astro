---
/**
 * Reusable hero banner with an optimized background image and overlaid content.
 * Content (eyebrow, heading, CTAs) is passed via props/slots so it stays generic.
 */
import { Image } from "astro:assets";
import { SITE } from "@data/site";
import Button from "@components/Button.astro";
import Icon from "@components/Icon.astro";

interface Props {
  eyebrow?: string;
  title: string;
  subtitle?: string;
  image: ImageMetadata;
  imageAlt: string;
  primaryHref?: string;
  primaryLabel?: string;
  secondaryHref?: string;
  secondaryLabel?: string;
}

const {
  eyebrow,
  title,
  subtitle,
  image,
  imageAlt,
  primaryHref = SITE.phoneHref,
  primaryLabel = `Call ${SITE.phone}`,
  secondaryHref = "/services/",
  secondaryLabel = "View Services",
} = Astro.props;
---

<section class="relative isolate overflow-hidden bg-ink-900">
  <Image
    src={image}
    alt={imageAlt}
    class="absolute inset-0 -z-10 h-full w-full object-cover opacity-35"
    loading="eager"
    fetchpriority="high"
    widths={[640, 960, 1280, 1920]}
    sizes="100vw"
  />
  <div class="absolute inset-0 -z-10 bg-gradient-to-r from-ink-900/90 via-ink-900/70 to-brand-900/40"></div>

  <div class="mx-auto max-w-6xl px-4 pb-16 pt-10 sm:px-6 sm:pb-20 sm:pt-12 lg:pb-24 lg:pt-14">
    <div class="grid items-stretch gap-10 lg:grid-cols-[minmax(0,1fr)_auto] lg:gap-12">
      <div class="flex min-h-[22rem] max-w-2xl flex-col sm:min-h-[26rem] lg:min-h-[28rem]">
        {
          eyebrow && (
            <p class="inline-flex w-fit items-center gap-2 rounded-full bg-white/10 px-3 py-1 text-sm font-medium text-brand-200 ring-1 ring-white/20">
              <Icon name="shield" class="h-4 w-4" />
              {eyebrow}
            </p>
          )
        }

        <div class="mt-6 sm:mt-8">
          <h1 class="text-4xl font-extrabold leading-tight text-white sm:text-5xl lg:text-6xl">
            {title}
          </h1>
          {
            subtitle && (
              <p class="mt-5 text-lg leading-relaxed text-ink-200 sm:text-xl">
                {subtitle}
              </p>
            )
          }
        </div>

        <div class="mt-auto flex flex-col items-start gap-3 pt-8 sm:flex-row sm:flex-wrap sm:items-center sm:pt-10 lg:pt-12">
          <Button href={primaryHref} variant="primary" size="lg">
            <Icon name="phone" class="h-5 w-5" />
            {primaryLabel}
          </Button>
          <Button
            href={SITE.smsHref}
            size="lg"
            class="bg-accent-600 text-white shadow-sm hover:bg-accent-700"
          >
            <Icon name="chat" class="h-5 w-5" />
            Text Us
          </Button>
          <Button href={secondaryHref} variant="outline" size="lg">
            {secondaryLabel}
          </Button>
        </div>
      </div>

      <div class="flex shrink-0 items-center justify-center lg:justify-end">
        <slot name="aside" />
      </div>
    </div>
  </div>
</section>
