---
/**
 * Consistent section header (eyebrow + title + optional lead text).
 */
interface Props {
  eyebrow?: string;
  title: string;
  align?: "left" | "center";
  class?: string;
}

const { eyebrow, title, align = "center", class: className = "" } = Astro.props;
const alignment = align === "center" ? "mx-auto text-center" : "text-left";
---

<div class={`max-w-2xl ${alignment} ${className}`}>
  {
    eyebrow && (
      <p class="text-sm font-bold uppercase tracking-wider text-brand-600">
        {eyebrow}
      </p>
    )
  }
  <h2 class="mt-2 text-3xl font-extrabold text-ink-900 sm:text-4xl">{title}</h2>
  <slot />
</div>
