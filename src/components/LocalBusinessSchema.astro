---
/**
 * Emits a JSON-LD @graph with Organization, LocalBusiness, and WebSite nodes.
 * This gives search engines and AI systems a clear model of the brand,
 * the physical business, and the site. Inert data — not executable client JS.
 */
import { SITE } from "@data/site";

const orgId = `${SITE.url}/#organization`;
const businessId = `${SITE.url}/#localbusiness`;
const websiteId = `${SITE.url}/#website`;
const logoUrl = new URL("/favicon.svg", SITE.url).href;
const imageUrl = new URL("/og-image.jpg", SITE.url).href;
const telephone = SITE.phoneHref.replace("tel:", "");

const postalAddress = {
  "@type": "PostalAddress",
  streetAddress: SITE.address.street,
  addressLocality: SITE.address.city,
  addressRegion: SITE.address.state,
  postalCode: SITE.address.zip,
  addressCountry: SITE.address.country,
};

const graph = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Organization",
      "@id": orgId,
      name: SITE.name,
      legalName: SITE.legalName,
      url: SITE.url,
      logo: { "@type": "ImageObject", url: logoUrl },
      image: imageUrl,
      email: SITE.email,
      telephone,
      description: SITE.description,
      address: postalAddress,
      ...(SITE.social.length > 0
        ? { sameAs: SITE.social.map((s) => s.href) }
        : {}),
    },
    {
      "@type": "HomeAndConstructionBusiness",
      "@id": businessId,
      name: SITE.name,
      parentOrganization: { "@id": orgId },
      url: SITE.url,
      image: imageUrl,
      telephone,
      email: SITE.email,
      priceRange: "$$",
      description: SITE.description,
      address: postalAddress,
      geo: {
        "@type": "GeoCoordinates",
        latitude: SITE.geo.latitude,
        longitude: SITE.geo.longitude,
      },
      areaServed: SITE.areasServed.map((name) => ({ "@type": "City", name })),
      openingHours: ["Mo-Fr 08:00-18:00", "Sa 09:00-14:00"],
    },
    {
      "@type": "WebSite",
      "@id": websiteId,
      url: SITE.url,
      name: SITE.name,
      publisher: { "@id": orgId },
      inLanguage: "en-US",
    },
  ],
};
---

<script
  type="application/ld+json"
  set:html={JSON.stringify(graph)}
  is:inline
/>
