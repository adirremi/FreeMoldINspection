---
import { getCollection } from "astro:content";
import BaseLayout from "@layouts/BaseLayout.astro";
import SectionHeading from "@components/SectionHeading.astro";
import ServiceCard from "@components/ServiceCard.astro";
import CTASection from "@components/CTASection.astro";

const services = (await getCollection("services")).sort(
  (a, b) => a.data.order - b.data.order
);
---

<BaseLayout
  title="Mold Inspection Services"
  description="Explore our full range of mold services: comprehensive inspection, laboratory testing, indoor air quality testing, moisture assessment, and residential & commercial inspections."
>
  <section class="bg-ink-900">
    <div class="mx-auto max-w-6xl px-4 py-16 sm:px-6 sm:py-20">
      <p class="text-sm font-bold uppercase tracking-wider text-brand-400">Services</p>
      <h1 class="mt-2 max-w-3xl text-4xl font-extrabold text-white sm:text-5xl">
        Complete Mold Inspection & Testing Services
      </h1>
      <p class="mt-5 max-w-2xl text-lg text-ink-200">
        Choose the service that fits your situation, or call us and we'll help
        you decide. Every option ends with a clear, honest report.
      </p>
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-4 py-16 sm:px-6 sm:py-20">
    <SectionHeading eyebrow="Our Offerings" title="Find the Right Service for You" />
    <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {
        services.map((service) => (
          <ServiceCard
            title={service.data.shortTitle}
            summary={service.data.summary}
            icon={service.data.icon}
            href={`/services/${service.id}/`}
          />
        ))
      }
    </div>
  </section>

  <CTASection title="Not sure which service you need?" />
</BaseLayout>
