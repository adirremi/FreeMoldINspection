---
import { getCollection } from "astro:content";
import { Image } from "astro:assets";
import BaseLayout from "@layouts/BaseLayout.astro";
import Hero from "@components/Hero.astro";
import HeroCredentialsRing from "@components/HeroCredentialsRing.astro";
import SectionHeading from "@components/SectionHeading.astro";
import ServiceCard from "@components/ServiceCard.astro";
import CTASection from "@components/CTASection.astro";
import FAQ from "@components/FAQ.astro";
import Icon from "@components/Icon.astro";
import { type IconName } from "@lib/icons";
import { GENERAL_FAQS } from "@lib/faqs";
import { SITE } from "@data/site";
import { CITIES } from "@data/locations";

import heroImage from "@assets/images/mold-inside-wall.jpeg";
import credentialsImage from "@assets/images/mold-assessor-remediator.jpeg";
import galleryWall from "@assets/images/mold-wall.jpeg";
import galleryBathroom from "@assets/images/mold-bathroom.jpeg";
import galleryKitchen from "@assets/images/mold-kitchen.jpeg";
import galleryCorners from "@assets/images/mold-corners.jpeg";
import galleryFloor from "@assets/images/mold-floor.jpeg";
import galleryTester from "@assets/images/mold-tester.jpeg";

const services = (await getCollection("services")).sort(
  (a, b) => a.data.order - b.data.order
);
const featured = services.filter((s) => s.data.featured);

const steps: { title: string; text: string }[] = [
  {
    title: "Free Visual Inspection",
    text: "We inspect the property for visible signs of mold, moisture intrusion, and water damage.",
  },
  {
    title: "Moisture Mapping & Thermal Imaging",
    text: "Advanced tools are used to identify hidden moisture and potential mold growth behind walls and ceilings.",
  },
  {
    title: "Air & Surface Sampling",
    text: "Samples are collected when necessary and submitted to an independent accredited laboratory.",
  },
  {
    title: "Laboratory Analysis",
    text: "All samples are analyzed by a certified third-party laboratory.",
  },
  {
    title: "Detailed Report & Recommendations",
    text: "You receive a comprehensive report with findings, lab results, and recommendations for next steps.",
  },
];

const whyChooseUs = [
  "Florida Licensed Mold Assessor",
  "Federal Government Registered Contractor\nUEI: SYX9K5L4MVA9\nCAGE: 21KV2",
  "IICRC Certified",
  "Same-Day Service Available",
  "Woman-Owned Business",
  "Independent Mold Testing",
  "EMSL Laboratory Analysis",
  "Insurance Claim Experience",
  "Statewide Florida Coverage",
];

const insuranceItems = [
  "Water Damage Documentation",
  "Moisture Readings",
  "Mold Testing",
  "Independent Laboratory Reports",
  "Insurance Support Documentation",
];

const reasons: { icon: IconName; title: string; text: string }[] = [
  {
    icon: "check",
    title: "Certified Inspectors",
    text: "Trained, certified professionals who know exactly where mold hides.",
  },
  {
    icon: "flask",
    title: "Accredited Lab Results",
    text: "Independent laboratory analysis you can trust and act on.",
  },
  {
    icon: "shield",
    title: "No-Pressure Reporting",
    text: "Honest findings without upselling unnecessary remediation.",
  },
  {
    icon: "clock",
    title: "Fast Turnaround",
    text: "Quick scheduling and prompt reporting when it matters most.",
  },
];

const gallery = [
  { src: galleryWall, alt: "Mold growth spreading across an interior wall" },
  { src: galleryBathroom, alt: "Mold buildup in a bathroom corner" },
  { src: galleryKitchen, alt: "Mold found inside a kitchen cabinet" },
  { src: galleryCorners, alt: "Inspector checking mold under wall corners" },
  { src: galleryFloor, alt: "Mold damage along flooring" },
  { src: galleryTester, alt: "Technician using a professional mold testing device" },
];
---

<BaseLayout
  title="Free Mold Inspection | Certified Mold Testing in Pembroke Park, FL"
  description={SITE.description}
  image="/og-image.jpg"
>
  <Hero
    eyebrow="Certified & Trusted Across Florida"
    title="Free Mold Inspection & Certified Mold Testing Across Florida"
    subtitle="Helping protect your home, your business, and the air your family breathes. We help uncover hidden mold with thermal imaging, moisture mapping, and accredited lab testing."
    image={heroImage}
    imageAlt="Mold discovered inside a damaged interior wall"
  >
    <HeroCredentialsRing slot="aside" />
  </Hero>

  <!-- Trust bar -->
  <section class="border-b border-ink-200 bg-ink-50">
    <div class="mx-auto grid max-w-6xl grid-cols-2 gap-6 px-4 py-8 sm:px-6 lg:grid-cols-4">
      {
        reasons.map((reason) => (
          <div class="flex items-start gap-3">
            <span class="inline-flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-accent-100 text-accent-700">
              <Icon name={reason.icon} class="h-5 w-5" />
            </span>
            <div>
              <p class="font-semibold text-ink-900">{reason.title}</p>
              <p class="text-sm text-ink-700">{reason.text}</p>
            </div>
          </div>
        ))
      }
    </div>
  </section>

  <!-- Services -->
  <section class="mx-auto max-w-6xl px-4 py-16 sm:px-6 sm:py-20">
    <SectionHeading eyebrow="What We Do" title="Mold Services Built Around Your Peace of Mind">
      <p class="mt-4 text-lg text-ink-700">
        From a single musty room to a whole commercial building, our services
        give you a clear, honest picture of your indoor environment.
      </p>
    </SectionHeading>

    <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {
        featured.map((service) => (
          <ServiceCard
            title={service.data.shortTitle}
            summary={service.data.summary}
            icon={service.data.icon}
            href={`/services/${service.id}/`}
          />
        ))
      }
    </div>

    <div class="mt-10 text-center">
      <a
        href="/services/"
        class="inline-flex items-center gap-1 font-semibold text-brand-700 hover:text-brand-800"
      >
        Explore all mold services
        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
      </a>
    </div>
  </section>

  <!-- Why Choose Us -->
  <section class="bg-ink-50">
    <div class="mx-auto max-w-6xl px-4 py-16 sm:px-6 sm:py-20">
      <SectionHeading eyebrow="Why Choose Us" title="Why Florida Homeowners Trust Us">
        <p class="mt-4 text-lg text-ink-700">
          Licensed, certified, and responsive — here's what you can count on
          when you work with our team.
        </p>
      </SectionHeading>

      <ul class="mx-auto mt-12 grid max-w-5xl gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {
          whyChooseUs.map((item) => (
            <li class="flex items-center gap-3 rounded-xl border border-ink-200 bg-white p-4 shadow-sm">
              <span class="inline-flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-accent-100 text-accent-700">
                <Icon name="check" class="h-5 w-5" />
              </span>
              <span class="whitespace-pre-line font-semibold text-ink-900">{item}</span>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <!-- Our Mold Inspection Process -->
  <section class="mx-auto max-w-6xl px-4 py-16 sm:px-6 sm:py-20">
    <SectionHeading eyebrow="How It Works" title="Our Mold Inspection Process" />
    <ol class="mx-auto mt-12 grid max-w-5xl gap-6 md:grid-cols-2">
      {
        steps.map((step, index) => (
          <li class="flex gap-4 rounded-2xl border border-ink-200 bg-white p-6 shadow-sm">
            <span
              class="inline-flex h-11 w-11 shrink-0 items-center justify-center rounded-full bg-brand-600 text-lg font-extrabold text-white shadow-sm"
              aria-hidden="true"
            >
              {index + 1}
            </span>
            <div>
              <h3 class="text-lg font-bold text-ink-900">{step.title}</h3>
              <p class="mt-1.5 text-ink-700">{step.text}</p>
            </div>
          </li>
        ))
      }
    </ol>
  </section>

  <!-- Insurance Claims -->
  <section class="bg-brand-900">
    <div class="mx-auto max-w-6xl px-4 py-16 sm:px-6 sm:py-20">
      <div class="grid items-center gap-10 lg:grid-cols-2">
        <div>
          <p class="text-sm font-bold uppercase tracking-wider text-brand-300">
            Insurance Support
          </p>
          <h2 class="mt-2 text-3xl font-extrabold text-white sm:text-4xl">
            Mold Inspection for Insurance Claims
          </h2>
          <p class="mt-4 text-lg text-brand-100">
            Filing a claim? We provide the independent documentation insurers ask
            for, so you can support your case with clear, third-party evidence.
          </p>
        </div>
        <ul class="grid gap-3 sm:grid-cols-2 lg:grid-cols-1">
          {
            insuranceItems.map((item) => (
              <li class="flex items-center gap-3 rounded-xl bg-white/10 px-4 py-3 ring-1 ring-white/15">
                <span class="inline-flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-accent-500 text-white">
                  <Icon name="check" class="h-4 w-4" />
                </span>
                <span class="font-medium text-white">{item}</span>
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </section>

  <!-- Gallery -->
  <section class="mx-auto max-w-6xl px-4 py-16 sm:px-6 sm:py-20">
    <SectionHeading
      eyebrow="What Mold Looks Like"
      title="Real Mold We Help Homeowners Identify"
    >
      <p class="mt-4 text-lg text-ink-700">
        Mold hides in walls, bathrooms, kitchens, and under floors. If anything
        looks familiar, it is worth getting inspected.
      </p>
    </SectionHeading>

    <div class="mt-12 grid grid-cols-2 gap-4 md:grid-cols-3">
      {
        gallery.map((item) => (
          <figure class="overflow-hidden rounded-2xl border border-ink-200 shadow-sm">
            <Image
              src={item.src}
              alt={item.alt}
              widths={[320, 480, 640]}
              sizes="(min-width: 768px) 30vw, 45vw"
              class="aspect-4/3 h-full w-full object-cover transition-transform duration-300 hover:scale-105"
              loading="lazy"
            />
          </figure>
        ))
      }
    </div>
  </section>

  <!-- Licensed & Certified -->
  <section class="bg-ink-50">
    <div class="mx-auto max-w-6xl px-4 py-16 sm:px-6 sm:py-20">
      <div class="grid items-center gap-10 lg:grid-cols-2">
        <SectionHeading eyebrow="Credentials" title="Licensed & Certified">
          <p class="mt-4 text-lg text-ink-700">
            State-licensed and industry-certified for both mold assessment and
            remediation — verifiable credentials you can rely on.
          </p>
          <ul class="mt-6 space-y-3 text-ink-700">
            <li class="flex items-center gap-2">
              <Icon name="check" class="h-5 w-5 shrink-0 text-accent-600" />
              <span><strong>MRSA3365</strong> — Florida Mold Assessor</span>
            </li>
            <li class="flex items-center gap-2">
              <Icon name="check" class="h-5 w-5 shrink-0 text-accent-600" />
              <span><strong>MRSR3576</strong> — Florida Mold Remediator</span>
            </li>
            <li class="flex items-center gap-2">
              <Icon name="check" class="h-5 w-5 shrink-0 text-accent-600" />
              <span><strong>IICRC Certified</strong> — Institute of Inspection Cleaning and Restoration Certification</span>
            </li>
          </ul>
        </SectionHeading>

        <figure class="overflow-hidden rounded-2xl border border-ink-200 bg-white shadow-sm">
          <Image
            src={credentialsImage}
            alt="A licensed mold assessor and a certified mold remediator in protective gear"
            widths={[480, 720, 1024]}
            sizes="(min-width: 1024px) 45vw, 100vw"
            class="h-full w-full object-cover"
            loading="lazy"
          />
        </figure>
      </div>
    </div>
  </section>

  <!-- Service Areas -->
  <section class="mx-auto max-w-6xl px-4 py-16 sm:px-6 sm:py-20">
    <SectionHeading eyebrow="Service Areas" title="Mold Inspection Across Florida">
      <p class="mt-4 text-lg text-ink-700">
        We serve homeowners and businesses statewide. Find your city below for
        local mold inspection and testing.
      </p>
    </SectionHeading>

    <ul class="mx-auto mt-10 flex max-w-5xl flex-wrap justify-center gap-3">
      {
        CITIES.map((city) => (
          <li>
            <a
              href={`/locations/${city.slug}/`}
              class="inline-flex items-center gap-2 rounded-full border border-ink-200 bg-white px-4 py-2 text-sm font-medium text-ink-800 shadow-sm transition hover:border-brand-300 hover:bg-brand-50 hover:text-brand-700"
            >
              <Icon name="map-pin" class="h-4 w-4 text-brand-600" />
              {city.name}
            </a>
          </li>
        ))
      }
    </ul>

    <div class="mt-8 text-center">
      <a
        href="/locations/"
        class="inline-flex items-center gap-1 font-semibold text-brand-700 hover:text-brand-800"
      >
        View all service areas
        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
      </a>
    </div>
  </section>

  <FAQ faqs={GENERAL_FAQS} />

  <CTASection />
</BaseLayout>
